APP_ENV=dev
TIMEZONE=Europe/Istanbul

# LLM Provider Switch: openai | gemini
LLM_PROVIDER=gemini

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Calendar
GOOGLE_CALENDAR_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Webview booking link security (min 32 bytes = 64 hex chars)
BOOKING_LINK_SECRET=
# Optional: set your ngrok/production URL here so links always use the right host
BOOKING_BASE_URL=

# Smart reminder policy: smart | double | single24 | single2 | none
REMINDER_MODE=smart

# KVKK consent metadata
KVKK_CONSENT_VERSION=v1
PRIVACY_NOTICE_URL=

# Funnel event logging
FUNNEL_LOG_ENABLED=true
